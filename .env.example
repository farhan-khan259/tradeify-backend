# Tradeify backend environment
PROJECT_NAME=Tradeify
API_V1_PREFIX=/api/v1

# ── Database (Supabase Postgres) ──────────────────────────────────────────────
# Supabase Dashboard -> Project Settings -> Database -> Connection string -> URI.
# Replace [PASSWORD] and [PROJECT-REF]/[REGION] with your project's values, and
# prefix the scheme with "+psycopg2".
#
# Session pooler (recommended for this app; keep DB_USE_NULL_POOL=false):
DATABASE_URL=postgresql+psycopg://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
#
# Transaction pooler (port 6543) -> also set DB_USE_NULL_POOL=true:
# DATABASE_URL=postgresql+psycopg://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

DB_USE_NULL_POOL=false

# Set false after you create the schema via db/schema.sql in the Supabase SQL editor.
AUTO_CREATE_TABLES=true

# Optional: only if you later use the supabase-py client / Storage / Auth.
# Service key is secret — backend only, never expose to the frontend.
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_SERVICE_KEY=

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALGORITHM=HS256
EXPOSE_FORGOT_PASSWORD_OTP=true
PASSWORD_RESET_OTP_EXPIRE_MINUTES=10

# SMTP (optional; if unset, forgot-password OTP stays in demo mode)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# CORS (comma-separated origins)
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Seed admin (created on first startup if no users exist)
FIRST_ADMIN_EMAIL=admin@tradeify.local
FIRST_ADMIN_PASSWORD=ChangeMe123!
